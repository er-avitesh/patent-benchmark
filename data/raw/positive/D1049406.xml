<description id="description">
<?brief-description-of-drawings description="Brief Description of Drawings" end="lead"?>
<description-of-drawings>
<p id="p-0001" num="0001"><figref idref="DRAWINGS">FIG. <b>1</b></figref> is a front, right and top perspective view of a beauty instrument assembly, showing my new design;</p>
<p id="p-0002" num="0002"><figref idref="DRAWINGS">FIG. <b>2</b></figref> is a rear, left and bottom perspective view thereof;</p>
<p id="p-0003" num="0003"><figref idref="DRAWINGS">FIG. <b>3</b></figref> is a front, right and top perspective view of the beauty instrument assembly in a disassembled status;</p>
<p id="p-0004" num="0004"><figref idref="DRAWINGS">FIG. <b>4</b></figref> is a front view thereof;</p>
<p id="p-0005" num="0005"><figref idref="DRAWINGS">FIG. <b>5</b></figref> is a rear view thereof;</p>
<p id="p-0006" num="0006"><figref idref="DRAWINGS">FIG. <b>6</b></figref> is a left side view thereof;</p>
<p id="p-0007" num="0007"><figref idref="DRAWINGS">FIG. <b>7</b></figref> is a right side view thereof;</p>
<p id="p-0008" num="0008"><figref idref="DRAWINGS">FIG. <b>8</b></figref> is a top plan view thereof; and,</p>
<p id="p-0009" num="0009"><figref idref="DRAWINGS">FIG. <b>9</b></figref> is a bottom plan view thereof.</p>
<p id="p-0010" num="0010">The broken lines shown in the drawings illustrate portions of the beauty instrument assembly that form no part of the claimed design.</p>
</description-of-drawings>
<?brief-description-of-drawings description="Brief Description of Drawings" end="tail"?>
